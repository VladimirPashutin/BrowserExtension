{
  "openrpc": "1.2.1",
  "info": {
    "version": "1.0.0",
    "title": "AI calls"
  },
  "servers": [
    {
      "url": "http://127.0.0.1:5000"
    }
  ],
  "methods": [
    {
      "name": "ping",
      "summary": "Creates dump operation with 10 seconds processing time",
      "tags": [
        {
          "name": "common"
        }
      ],
      "params": [],
      "result": {
        "name": "CreateOperationResponse",
        "schema": {
          "$ref": "#/components/schemas/CreateOperationResponse"
        }
      },
      "errors": [
        {
          "code": 401,
          "message": "Unauthorized"
        },
        {
          "code": 400,
          "message": "Bad request"
        },
        {
          "code": 429,
          "message": "Too Many Requests"
        },
        {
          "code": 500,
          "message": "Internal Server Error"
        }
      ]
    },
    {
      "name": "get_result",
      "summary": "Get result of operation processing. If operation is not finished yet, return only status",
      "tags": [
        {
          "name": "common"
        }
      ],
      "params": [
        {
          "name": "operation_id",
          "description": "Operation id",
          "required": true,
          "schema": {
            "type": "integer"
          }
        }
      ],
      "result": {
        "name": "ResultOperationResponse",
        "schema": {
          "$ref": "#/components/schemas/ResultOperationResponse"
        }
      },
      "errors": [
        {
          "code": 401,
          "message": "Unauthorized"
        },
        {
          "code": 400,
          "message": "Bad request"
        },
        {
          "code": 429,
          "message": "Too Many Requests"
        },
        {
          "code": 500,
          "message": "Internal Server Error"
        }
      ]
    },
    {
      "name": "answer_review",
      "summary": "Call ai tool to generate answer on user review",
      "tags": [
        {
          "name": "reviews"
        }
      ],
      "params": [
        {
          "name": "rate",
          "description": "How many stars review rated",
          "required": false,
          "schema": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          }
        },
        {
          "name": "author",
          "description": "User name",
          "required": false,
          "schema": {
            "type": "string"
          }
        },
        {
          "name": "full_text",
          "description": "Full text of review",
          "required": false,
          "schema": {
            "type": "string"
          }
        },
        {
          "name": "photos",
          "description": "List of user photo urls",
          "required": false,
          "schema": {
            "type": "string"
          }
        }
      ],
      "result": {
        "name": "CreateOperationResponse",
        "schema": {
          "$ref": "#/components/schemas/CreateOperationResponse"
        }
      },
      "errors": [
        {
          "code": 401,
          "message": "Unauthorized"
        },
        {
          "code": 400,
          "message": "Bad request"
        },
        {
          "code": 429,
          "message": "Too Many Requests"
        },
        {
          "code": 500,
          "message": "Internal Server Error"
        }
      ]
    }
  ],
  "components": {
    "schemas": {
      "CreateOperationResponse": {
        "type": "object",
        "required": [
          "id",
          "status"
        ],
        "properties": {
          "id": {
            "type": "integer"
          },
          "status": {
            "type": "string"
          },
          "error": {
            "type": "string"
          }
        }
      },
      "ResultOperationResponse": {
        "type": "object",
        "required": [
          "status"
        ],
        "properties": {
          "status": {
            "type": "string"
          },
          "result": {
            "type": "string"
          },
          "error": {
            "type": "string"
          }
        }
      },
      "Status": {
        "type": "string",
        "enum": [
          "processing",
          "done",
          "error"
        ]
      },
      "PhotoUrl": {
        "type": "string"
      },
      "PhotoList": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/PhotoUrl"
        }
      }
    }
  }
}